# .npmrc
#
# npm configuration for the nexeditor monorepo.
#
# provenance=true:
#   Automatically attaches npm provenance to all packages published
#   from this repository. Provenance creates a cryptographic link
#   between the published package and the GitHub Actions run that
#   produced it. Consumers can verify the package origin.
#   Requires Node.js >= 18 and npm >= 9.5.
#
# save-exact=true:
#   Lock dependency versions in package.json to exact versions
#   instead of using ^ or ~ ranges. Prevents surprising updates
#   when developers run npm install on a fresh clone.
#   This is especially important for security-sensitive packages.
#
# engine-strict=true:
#   Enforce the engines field in package.json.
#   Prevents developers from accidentally running the project
#   with an unsupported Node.js version.

provenance=true
save-exact=false
engine-strict=true